.ipynb_checkpoints/
*.nbconvert.ipynb
*.ipynb_convert/
profile_default/
ipython_config.py

# Jupyter large checkpoints / autosaves
*.checkpoint.ipynb

# ==========================================
# Data Files (Generated / Large / Private)
# ==========================================
data/generated/
data/processed/
data/san_diego_energy_load_data.csv
data/segments/
# Raw data (optional: keep small samples only)
data/raw/*.csv
!data/raw/sample_*.csv     # keep small sample files

# Tuning artifacts
tuning.db
tuning_results.csv

# Model output files
models/**/*.joblib
models/**/*.pkl
models/**/*.h5
models/**/*.pt

# Model comparison summary
model_comparison_summary.csv

# Cached training results
*.npz
*.npy

