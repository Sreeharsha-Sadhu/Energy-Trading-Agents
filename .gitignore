node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# Project-Specific Ignore
# ==========================================

# JSON configs and metadata that should not be public
*.json

# Except documentation JSON files if needed
!docs/*.json

# Notebook metadata copies
covidImpactAnalysis.json
modelComparison.json
modelTuning.json
postCovidTuning.json

# Energy data tracking
Docs/data_generation_tracking.json

